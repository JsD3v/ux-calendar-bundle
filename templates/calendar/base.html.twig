<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <title>{% block calendar_title %}{{ 'calendar.title'|trans({}, 'calendar') }}{% endblock %}</title>

    {# Optional framework CDN assets. Disabled by default. #}
    {{ calendar_framework_css()|raw }}

    {# Calendar core CSS and selected theme variables. #}
    {{ calendar_theme_css()|raw }}

    {% block calendar_stylesheets %}{% endblock %}
</head>
<body>
    {# Zone pour les messages flash (Turbo Streams) #}
    <div id="flash-messages" class="container mt-3"></div>

    {# Messages flash normaux #}
    {% for type, messages in app.flashes %}
        <div class="container mt-3">
            {% for message in messages %}
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                    {{ message|trans({}, 'calendar') }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'calendar.action.close'|trans({}, 'calendar') }}"></button>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    {% block calendar_body %}{% endblock %}

    {# Optional framework CDN assets. Disabled by default. #}
    {{ calendar_framework_js()|raw }}

    {# Renders the application's AssetMapper entrypoint so the bundle's Stimulus
       controller AND the app's own assets (e.g. Bootstrap declared in
       importmap.php) are loaded on the standalone calendar pages.
       Override this block if your entrypoint is not named "app". #}
    {% block importmap %}
        {{ importmap('app') }}
    {% endblock %}

    {% block calendar_javascripts %}{% endblock %}
</body>
</html>
