{% extends '@Calendar/calendar/base.html.twig' %}

{% block calendar_title %}{{ 'calendar.new.title'|trans({}, 'calendar') }}{% endblock %}

{% block calendar_body %}
<turbo-frame id="event-modal">
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ 'calendar.new.title'|trans({}, 'calendar') }}</h5>
                    <a href="{{ path('calendar_index') }}" 
                       class="btn-close" 
                       data-turbo-frame="event-modal"
                       aria-label="{{ 'calendar.action.close'|trans({}, 'calendar') }}"></a>
                </div>
                
                {{ form_start(form, {
                    'action': path('calendar_event_new', {view: view|default('month')}),
                    'attr': {
                        'data-turbo': 'true',
                        'data-turbo-frame': 'event-modal'
                    }
                }) }}
                
                <div class="modal-body">
                    {{ form_row(form.title) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.startDate) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.endDate) }}
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        {{ form_row(form.allDay) }}
                    </div>
                    
                    {{ form_row(form.description) }}
                    
                    {{ form_row(form.color) }}
                </div>
                
                <div class="modal-footer">
                    <a href="{{ path('calendar_index') }}" 
                       class="btn btn-secondary"
                       data-turbo-frame="event-modal">
                        {{ 'calendar.action.cancel'|trans({}, 'calendar') }}
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> {{ 'calendar.action.create_event'|trans({}, 'calendar') }}
                    </button>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</turbo-frame>
{% endblock %}
